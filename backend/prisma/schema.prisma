generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  CARPINTERO
  OPERARIO
  EMPLEADO
}

enum EstadoPedido {
  PENDIENTE
  EN_PROCESO
  TERMINADA
  ENTREGADA
  RECHAZADA
}

enum TipoMaterial {
  PLACA
  CANTO
}

model Usuario {
  id            String          @id @default(uuid())
  nombre        String
  apellido      String
  email         String          @unique
  password      String?
  telefono      String?
  googleId      String?         @unique
  rol           Rol             @default(CARPINTERO)
  fechaCreacion DateTime        @default(now())
  pedidos       Pedido[]
  auditorias    Auditoria[]     @relation("AuditoriaUsuario")
  cambios       HistorialPedido[] @relation("CambioUsuario")
  pushSubscriptions PushSubscription[]

  @@map("usuarios")
}

model Pedido {
  id            String            @id @default(uuid())
  cliente       String
  numeroContacto String?
  observaciones String?
  estado        EstadoPedido      @default(PENDIENTE)
  usuarioId     String
  fechaCreacion DateTime          @default(now())
  fechaActualizacion DateTime     @updatedAt
  usuario       Usuario           @relation(fields: [usuarioId], references: [id])
  detalles      DetallePedido[]
  historial     HistorialPedido[]

  @@index([estado])
  @@index([cliente])
  @@index([fechaCreacion])
  @@map("pedidos")
}

model Material {
  id                 String          @id @default(uuid())
  nombre             String          @unique
  tipo               TipoMaterial    @default(PLACA)
  valor              Float
  espesorMm          Float           @default(18)
  anchoPlaca         Int?
  altoPlaca          Int?
  colorCanto         String?
  stockPlacas        Int?
  activo             Boolean         @default(true)
  fechaCreacion      DateTime        @default(now())
  fechaActualizacion DateTime        @updatedAt
  detalles           DetallePedido[]

  @@index([tipo])
  @@index([activo])
  @@map("materiales")
}

model DetallePedido {
  id                 String  @id @default(uuid())
  pedidoId           String
  materialId         String?
  codigoBarra        String
  material           String
  largo              Int
  ancho              Int
  cantidad           Int
  cantoLargo1Id      String?
  cantoLargo1Nombre  String?
  cantoLargo1        Boolean @default(false)
  cantoLargo2Id      String?
  cantoLargo2Nombre  String?
  cantoLargo2        Boolean @default(false)
  cantoAncho1Id      String?
  cantoAncho1Nombre  String?
  cantoAncho1        Boolean @default(false)
  cantoAncho2Id      String?
  cantoAncho2Nombre  String?
  cantoAncho2        Boolean @default(false)
  permiteRotar       Boolean @default(false)
  codigoBarraCentro  String?
  remark             String?
  numeroCliente      String?
  nombreCliente      String?
  nombreProducto     String?
  pedido             Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  materialRef        Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([materialId])

  @@map("detalle_pedidos")
}

model HistorialPedido {
  id            String       @id @default(uuid())
  pedidoId      String
  usuarioId     String
  accion        String
  valorAnterior String?
  valorNuevo    String?
  fechaCreacion DateTime     @default(now())
  pedido        Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario       Usuario      @relation("CambioUsuario", fields: [usuarioId], references: [id])

  @@index([pedidoId])
  @@map("historial_pedidos")
}

model Auditoria {
  id            String   @id @default(uuid())
  usuarioId     String?
  accion        String
  entidad       String
  entidadId     String?
  metadata      Json?
  fechaCreacion DateTime @default(now())
  usuario       Usuario? @relation("AuditoriaUsuario", fields: [usuarioId], references: [id])

  @@index([entidad])
  @@map("auditorias")
}

model ConfiguracionOptimizador {
  id                 String   @id @default("default")
  espesorSierraMm    Float    @default(4.3)
  perfiladoBordeMm   Int      @default(10)
  fechaActualizacion DateTime @updatedAt

  @@map("configuracion_optimizador")
}

model ConfiguracionEmpresa {
  id                 String   @id @default("default")
  nombre             String   @default("ROMA")
  telefono           String   @default("")
  email              String   @default("")
  fechaActualizacion DateTime @updatedAt

  @@map("configuracion_empresa")
}

model PushSubscription {
  id                 String   @id @default(uuid())
  endpoint           String   @unique
  p256dh             String
  auth               String
  userAgent          String?
  usuarioId          String
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  usuario            Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("push_subscriptions")
}
